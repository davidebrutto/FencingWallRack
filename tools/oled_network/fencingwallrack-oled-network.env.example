# Copy to: /etc/default/fencingwallrack-oled-network

# Ethernet interface to configure. Wi-Fi is intentionally not editable here.
NET_IFACE=eth0

# OLED SPI display pins. Defaults match common 1.3 inch OLED HAT layouts.
OLED_SPI_PORT=0
OLED_SPI_DEVICE=0
OLED_WIDTH=128
OLED_HEIGHT=64
OLED_ROTATE=0
# Rotate the rendered OLED content by 180 degrees.
OLED_FLIP_180=1
# Rotate joystick directions by 180 degrees. K1/K2/K3 and center press are unchanged.
OLED_INPUT_FLIP_180=1
OLED_GPIO_DC=24
OLED_GPIO_RST=25
# Standby logo. Use a 128x64 px high-contrast PNG for best OLED rendering.
OLED_LOGO_PATH=/home/fencewall/FencingWallRack/tools/oled_network/logo.png
OLED_LOGO_TIMEOUT_SEC=10
# Kiosk profile controlled from OLED: ledwall or sottopedana.
KIOSK_ENV_PATH=/etc/default/fencingwallrack-kiosk
KIOSK_SERVICE=fencingwallrack-kiosk.service
OLED_DEFAULT_DISPLAY_PROFILE=ledwall
# When OUT changes between ledwall and sottopedana, reboot so desktop/kiosk reload cleanly.
OLED_REBOOT_ON_PROFILE_SAVE=1
OLED_REBOOT_DELAY_SEC=2
OLED_RESTART_KIOSK_ON_PROFILE_SAVE=1

# Buttons / joystick GPIO pins.
OLED_BTN_UP=6
OLED_BTN_DOWN=19
OLED_BTN_LEFT=5
OLED_BTN_RIGHT=26
OLED_BTN_PRESS=13
OLED_BTN_K1=21
OLED_BTN_K2=20
OLED_BTN_K3=16

# Used when there is no current IPv4 address to edit.
OLED_DEFAULT_IP=192.168.1.50
OLED_DEFAULT_PREFIX=24
OLED_DEFAULT_GATEWAY=192.168.1.1
