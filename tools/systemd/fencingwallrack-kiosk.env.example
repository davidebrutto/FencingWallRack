# Copy to: /etc/default/fencingwallrack-kiosk

# Project path on Raspberry
APP_DIR=/home/pi/FencingWallRack

# Node app endpoint used by Chromium kiosk
KIOSK_URL=http://127.0.0.1:5000

# X session used by kiosk browser
DISPLAY=:0
XAUTHORITY=/home/pi/.Xauthority
CHROMIUM_PROFILE_DIR=/home/pi/.config/fencing-kiosk
KIOSK_WINDOW_MODE=dual
KIOSK_SCALE=0.5
KIOSK_LEFT_PROFILE_DIR=/home/pi/.config/chrome-profile-1
KIOSK_RIGHT_PROFILE_DIR=/home/pi/.config/chrome-profile-2
KIOSK_LEFT_GEOMETRY=0,1,768,414
KIOSK_RIGHT_GEOMETRY=0,514,768,414

# Optional startup timeout (seconds)
STARTUP_TIMEOUT_SEC=90

# Serial settings used by server.js
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=38400
SERIAL_MODE=soh_eot
HOST=0.0.0.0
PORT=5000

# Optional remote media server.
# If enabled, startup clears local pause videos/photos, downloads all pause videos,
# and downloads athlete photos on demand when names arrive from USB.
# Expected manifests:
#   $REMOTE_ASSET_BASE_URL/pause-videos/manifest.json
#   $REMOTE_ASSET_BASE_URL/athlete-photos/manifest.json
# Manifest examples:
#   ["intro.mp4", "sponsor.mp4"]
#   [{"filename":"BRUTTO D.jpg","athleteName":"BRUTTO D.","url":"athlete-photos/BRUTTO%20D.jpg"}]
#REMOTE_ASSET_BASE_URL=https://example.com/fencingwallrack-assets
#REMOTE_VIDEO_MANIFEST_PATH=/pause-videos/manifest.json
#REMOTE_PHOTO_MANIFEST_PATH=/athlete-photos/manifest.json
#REMOTE_ASSET_TIMEOUT_MS=15000
