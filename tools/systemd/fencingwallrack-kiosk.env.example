# Copy to: /etc/default/fencingwallrack-kiosk

# Project path on Raspberry
APP_DIR=/home/fencewall/FencingWallRack

# Node app endpoint used by Chromium kiosk
KIOSK_URL=http://127.0.0.1:5000
# Display profile: ledwall or sottopedana.
KIOSK_DISPLAY_PROFILE=ledwall
# Optional desktop wallpaper switch tied to KIOSK_DISPLAY_PROFILE.
KIOSK_SET_WALLPAPER=1
KIOSK_WALLPAPER_MODE=fit
KIOSK_WALLPAPER_BACKEND=auto
KIOSK_LEDWALL_WALLPAPER=/home/fencewall/FencingWallRack/static/desktop-ledwall.png
KIOSK_UNDERFLOOR_WALLPAPER=/home/fencewall/FencingWallRack/static/desktop-sottopedana.png

# X session used by kiosk browser
DISPLAY=:0
XAUTHORITY=/home/fencewall/.Xauthority
CHROMIUM_PROFILE_DIR=/home/fencewall/.config/fencing-kiosk
KIOSK_WINDOW_MODE=dual
KIOSK_LEFT_PROFILE_DIR=/home/fencewall/.config/chrome-profile-1
KIOSK_RIGHT_PROFILE_DIR=/home/fencewall/.config/chrome-profile-2
KIOSK_UNDERFLOOR_LEFT_A_PROFILE_DIR=/home/fencewall/.config/chrome-underfloor-left-a
KIOSK_UNDERFLOOR_LEFT_B_PROFILE_DIR=/home/fencewall/.config/chrome-underfloor-left-b
KIOSK_UNDERFLOOR_RIGHT_A_PROFILE_DIR=/home/fencewall/.config/chrome-underfloor-right-a
KIOSK_UNDERFLOOR_RIGHT_B_PROFILE_DIR=/home/fencewall/.config/chrome-underfloor-right-b

# Ledwall profile: two 2m x 1m windows. The lower/rear display mirrors SX/DX.
KIOSK_LEDWALL_SCALE=0.5
KIOSK_LEDWALL_LEFT_URL=http://127.0.0.1:5000
KIOSK_LEDWALL_RIGHT_URL=http://127.0.0.1:5000/rear
KIOSK_LEDWALL_LEFT_GEOMETRY=0,1,768,414
KIOSK_LEDWALL_RIGHT_GEOMETRY=0,514,768,414

# Sottopedana profile: four visible 1344 x 96 windows stacked vertically.
KIOSK_UNDERFLOOR_SCALE=1
KIOSK_UNDERFLOOR_LEFT_A_URL=http://127.0.0.1:5000/underfloor-left-a
KIOSK_UNDERFLOOR_LEFT_B_URL=http://127.0.0.1:5000/underfloor-left-b
KIOSK_UNDERFLOOR_RIGHT_A_URL=http://127.0.0.1:5000/underfloor-right-a
KIOSK_UNDERFLOOR_RIGHT_B_URL=http://127.0.0.1:5000/underfloor-right-b
KIOSK_UNDERFLOOR_LEFT_A_GEOMETRY=30,30,1344,96
KIOSK_UNDERFLOOR_LEFT_B_GEOMETRY=30,226,1344,96
KIOSK_UNDERFLOOR_RIGHT_A_GEOMETRY=30,422,1344,96
KIOSK_UNDERFLOOR_RIGHT_B_GEOMETRY=30,618,1344,96

# Optional startup timeout (seconds)
STARTUP_TIMEOUT_SEC=90

# Serial settings used by server.js
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=38400
SERIAL_MODE=soh_eot
HOST=0.0.0.0
PORT=5000

# Optional remote media server.
# If enabled, startup clears local pause videos/photos, downloads all pause videos,
# and downloads athlete photos on demand when names arrive from USB.
# Expected manifests:
#   $REMOTE_ASSET_BASE_URL/pause-videos/manifest.json
#   $REMOTE_ASSET_BASE_URL/athlete-photos/manifest.json
# Manifest examples:
#   ["intro.mp4", "sponsor.mp4"]
#   [{"filename":"BRUTTO D.jpg","athleteName":"BRUTTO D.","url":"athlete-photos/BRUTTO%20D.jpg"}]
#REMOTE_ASSET_BASE_URL=https://example.com/fencingwallrack-assets
#REMOTE_VIDEO_MANIFEST_PATH=/pause-videos/manifest.json
#REMOTE_PHOTO_MANIFEST_PATH=/athlete-photos/manifest.json
#REMOTE_ASSET_TIMEOUT_MS=15000
