# Copy to: /etc/default/fencingwallrack-kiosk

# Project path on Raspberry
APP_DIR=/home/pi/FencingWallRack

# Node app endpoint used by Chromium kiosk
KIOSK_URL=http://127.0.0.1:5000

# X session used by kiosk browser
DISPLAY=:0
XAUTHORITY=/home/pi/.Xauthority
CHROMIUM_PROFILE_DIR=/home/pi/.config/fencing-kiosk
KIOSK_WINDOW_MODE=dual
KIOSK_SCALE=0.5
KIOSK_LEFT_PROFILE_DIR=/home/pi/.config/chrome-profile-1
KIOSK_RIGHT_PROFILE_DIR=/home/pi/.config/chrome-profile-2
KIOSK_LEFT_GEOMETRY=0,1,962,414
KIOSK_RIGHT_GEOMETRY=455,1,962,414

# Optional startup timeout (seconds)
STARTUP_TIMEOUT_SEC=90

# Serial settings used by server.js
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=38400
SERIAL_MODE=soh_eot
HOST=0.0.0.0
PORT=5000
